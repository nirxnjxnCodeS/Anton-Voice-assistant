<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.niranjan.anton.wake</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/niranjansbinu/.local/bin/uv</string>
        <string>run</string>
        <string>wake</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/niranjansbinu/Downloads/Anton Voice Agent</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/niranjansbinu/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/niranjansbinu</string>
        <!-- Prevents ctranslate2 semaphore crash under launchd -->
        <key>OMP_NUM_THREADS</key>
        <string>1</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!-- 5 min restart delay — gives model download time to finish on first run -->
    <key>ThrottleInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/Users/niranjansbinu/Library/Logs/anton-wake.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/niranjansbinu/Library/Logs/anton-wake.log</string>
</dict>
</plist>
