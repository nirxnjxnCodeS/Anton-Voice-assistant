# LiveKit credentials (get from https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# Sarvam AI API key (get from https://dashboard.sarvam.ai)
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# Supabase configuration for ticketing 
SUPABASE_URL=https://your-project-id.supabase.co/rest/v1
SUPABASE_API_KEY=your-supabase-api-key

GOOGLE_API_KEY=you-google-api-key (from https://aistudio.google.com/projects)

OPENWEATHER_API_KEY=your_key_here

# Google OAuth2 — path to the credentials JSON downloaded from Google Cloud Console
# Default: credentials.json in the project root. Only change if you put it elsewhere.
GOOGLE_CREDENTIALS_FILE=credentials.json

# Your local timezone for calendar event display (IANA format)
# Default: Asia/Kolkata. See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# Spotify — get credentials from https://developer.spotify.com/dashboard
# Create an app, add http://localhost:8888/callback as a Redirect URI in its settings
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback



OBSIDIAN_VAULT_PATH=/Users/niranjansbinu/Documents/Anton brain
